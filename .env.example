# InversionWharf — учебное окружение
# Скопируй в .env и замени значения перед запуском docker-compose.
# Никогда не коммить .env в git.

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=inversionwharf
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Базы данных (создаются при старте)
AUTH_DB=auth_db
CATALOG_DB=catalog_db
ENTITLEMENT_DB=entitlement_db
LICENSE_DB=license_db

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID_ENTITLEMENT=entitlement-group
KAFKA_GROUP_ID_TELEMETRY=telemetry-group

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis

# ─── auth-service / JWT ───────────────────────────────────────────────────────
# Генерация: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# В учебной версии — пути к файлам внутри контейнера (volume mount).
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
JWT_ACCESS_TOKEN_TTL_SECONDS=3600
JWT_REFRESH_TOKEN_TTL_SECONDS=86400

# ─── license-service / лизовый ключ ──────────────────────────────────────────
# Отдельная пара ключей для подписи лицензионных лизов (Ed25519 или RS256).
# Публичный ключ пиннется в License SDK продуктов.
LICENSE_SIGNING_PRIVATE_KEY_PATH=/run/secrets/license_private_key
LICENSE_SIGNING_PUBLIC_KEY_PATH=/run/secrets/license_public_key

# ─── Spring Cloud Config ──────────────────────────────────────────────────────
CONFIG_SERVER_URL=http://config-server:8888
CONFIG_SERVER_USERNAME=config
CONFIG_SERVER_PASSWORD=changeme_config

# ─── Eureka (Service Registry) ───────────────────────────────────────────────
EUREKA_SERVER_URL=http://service-registry:8761/eureka
EUREKA_USERNAME=eureka
EUREKA_PASSWORD=changeme_eureka

# ─── API Gateway ──────────────────────────────────────────────────────────────
GATEWAY_PORT=8090
CORS_ALLOWED_ORIGINS=http://localhost:8080

# ─── operator-web ─────────────────────────────────────────────────────────────
OPERATOR_WEB_PORT=8080

# ─── agent ────────────────────────────────────────────────────────────────────
AGENT_PORT=8095
# Сервисный JWT для агента (в учебной версии — статический API-ключ, не mTLS)
AGENT_SERVICE_CLIENT_ID=agent-service
AGENT_SERVICE_CLIENT_SECRET=changeme_agent_secret
# Интервал опроса каталога (секунды)
AGENT_CATALOG_POLL_INTERVAL_SECONDS=30
